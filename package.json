{
  "name": "paperless2papra",
  "type": "module",
  "version": "1.0.3",
  "packageManager": "pnpm@10.33.0",
  "description": "CLI migration tool to export documents from Paperless-ngx and import them into Papra.",
  "author": "Benjamin",
  "license": "AGPL-3.0-or-later",
  "keywords": ["papra", "paperless", "paperless-ngx", "migration", "cli", "document-management"],
  "exports": {
    ".": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "bin": {
    "paperless2papra": "./bin/cli.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx ./src/cli.ts",
    "build": "npx tsdown",
    "build:watch": "npx tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@papra/api-sdk": "^1.2.0",
    "citty": "^0.2.2",
    "ofetch": "^1.4.1",
    "picocolors": "^1.1.1",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.0.0",
    "@types/node": "^25.6.2",
    "eslint": "^9.0.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
